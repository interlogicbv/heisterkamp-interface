# URL van de API waar elke run een GET-request naartoe gaat (verplicht)
API_URL=

# Authorization-header voor de API (de key wordt letterlijk als headerwaarde gebruikt)
API_AUTHORIZATION=

# Minuten tussen twee runs (standaard: 5)
INTERVAL_MINUTES=5

# Pad van het XML-bestand dat weggeschreven wordt (standaard: output/data.xml)
OUTPUT_FILE=output/trucks.xml

# Naam van het root-element in de XML (standaard: root)
XML_ROOT_ELEMENT=trucks

# Optioneel: alleen dit deel van de JSON-response omzetten (dot-notatie).
# De Heisterkamp-API verpakt de resultaten in {"meta":..., "data":..., "errors":...};
# met "data" komt alleen de inhoud daarvan in de XML.
JSON_DATA_PATH=data

# Alleen trucks met deze activiteitscodes opnemen, met alleen de relevante velden
# (30 = Laden, 40 = Lossen). Gebruik * voor alle trucks in compacte vorm.
# Leeg laten = volledige, ongefilterde output.
ACTIVITY_CODES=30,40

# --- Optionele MSSQL-koppeling om ids aan de trucks te matchen ---
# Alleen actief als DB_SERVER is ingevuld (en ACTIVITY_CODES aan staat).
# DB_SERVER=
# DB_PORT=1433
# DB_DATABASE=
# DB_USER=
# DB_PASSWORD=
# De query moet minimaal de id-kolom en de match-kolom teruggeven:
# DB_QUERY=SELECT id, truck_number FROM dbo.trucks
# Kolom met het id dat in de XML komt (standaard: id)
# DB_ID_COLUMN=id
# Kolom in het queryresultaat én veld van de truck waarop gematcht wordt,
# bijv. truck_number of license_plate (standaard: truck_number)
# DB_MATCH_COLUMN=truck_number
